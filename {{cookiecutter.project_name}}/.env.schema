# This env file uses @env-spec - see https://varlock.dev/env-spec for more info
# @plugin(@varlock/proton-pass-plugin@0.0.3)
# @initProtonPass()
# @defaultRequired=true @defaultSensitive=false
{%- if cookiecutter.use_azure_auth == "y" %}
# @import(./.env.azure.schema, enabled=eq($AUTH_MODE, "azure"))
{%- endif %}
# ----------

# The app mode controls the varlock validation:
# on dev all env variables get validated
# on build only the for build required variables get validated (good for docker build)
# on prod only the runtime required variables get validated (good for docker run)
# @type=enum(dev, ci, build, prod)
APP_MODE=dev

{%- if cookiecutter.use_azure_auth == "y" %}
# When none authentication is disabled
# @type=enum(none, azure)
AUTH_MODE="none"
{%- endif %}

# @type=enum(debug, trace, info, warn, error, fatal, DEBUG, TRACE, INFO, WARN, ERROR, FATAL)
LOG_LEVEL=ifs(
    eq($APP_MODE, dev), debug,
    eq($APP_MODE, ci), debug,
    eq($APP_MODE, build), info,
    eq($APP_MODE, prod), info,
    debug
)

## Ports

# The port of the fastapi backend app
# @type=port
PORT=8000

# @type=port
LLM_API_PORT=8001

# @type=port
CLIENT_PORT=3000

## Urls

# The URL for client application
# @type=url
CLIENT_URL=if(
    eq($APP_MODE, "dev"), http://localhost:${CLIENT_PORT}, )

# The URL for LLM API
# @type=url
LLM_URL=if(
    eq($APP_MODE, "dev"), "http://localhost:${LLM_API_PORT}/v1", )

# The URL for LLM health check API
# @type=url
LLM_HEALTH_CHECK_URL=if(
    eq($APP_MODE, "dev"), "http://localhost:${LLM_API_PORT}/health", )

## LLM

# The model for LLM API
# @type=string
LLM_MODEL='Qwen/Qwen3-32B-AWQ'

# The API key for authenticating with the LLM
# @sensitive=eq($APP_MODE, "prod")
LLM_API_KEY=none

## Secrets
{% if cookiecutter.use_azure_auth == "y" %}

# Used to pseudonymize user id. Create with openssl rand 32 | base64
# @sensitive=$IS_PROD
HMAC_SECRET=

# Authentication mode
# @type=enum(none, azure)
AUTH_MODE="none"

# Azure AD client ID
# @sensitive
AZURE_CLIENT_ID=

# Azure AD tenant ID
# @sensitive
AZURE_TENANT_ID=

# Azure AD frontend client ID
# @sensitive
AZURE_FRONTEND_CLIENT_ID=

# Azure AD scope description
# @type=string
AZURE_SCOPE_DESCRIPTION="user_impersonation"
{% endif %}

## Flags

# Flag to indicate if the environment is production used for the logger
# @type=enum(True, False)
IS_PROD=eq($APP_MODE, "prod")

## Caching dirs for docker
# ---

# home directory should be set on linux
# @required
HOME=
CACHE_DIR="${HOME}/cache"
HUGGING_FACE_CACHE_DIR=${CACHE_DIR}/huggingface

# only needed for the VLLM docker container
# @optional @sensitive
HUGGING_FACE_HUB_TOKEN=protonPass("pass://DCC-KI/HUGGING_FACE_TOKEN/TOKEN", allowMissing=true)
